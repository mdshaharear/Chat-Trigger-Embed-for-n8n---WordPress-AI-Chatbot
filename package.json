{
  "name": "chat-trigger-embed-for-n8n",
  "version": "2.0.0",
  "private": true,
  "description": "WordPress plugin that embeds the official n8n Chat Trigger experience.",
  "author": {
    "name": "MD Shaharear",
    "url": "https://shaharear.com.bd"
  },
  "homepage": "https://shaharear.com.bd",
  "license": "GPL-2.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
