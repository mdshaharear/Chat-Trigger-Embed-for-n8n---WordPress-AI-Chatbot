    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.15.29",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.29.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
